# ──────────────────────────────────────────────
# Claude Code personal memory (local only)
# ──────────────────────────────────────────────
.claude/

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.pytype/

# ──────────────────────────────────────────────
# Backend runtime storage (uploaded user files)
# ──────────────────────────────────────────────
backend/storage/

# ──────────────────────────────────────────────
# Node / Next.js  (frontend submodule has its own .gitignore,
# but guard here too in case of accidental nesting)
# ──────────────────────────────────────────────
node_modules/
.next/
out/
/build

# ──────────────────────────────────────────────
# Environment & secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# OS / editor artefacts
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.pem
*.tsbuildinfo
next-env.d.ts
.vercel

# ──────────────────────────────────────────────
# Tooling caches (ruff, swc) and OMC working state
# ──────────────────────────────────────────────
.ruff_cache/
.swc/
.omc/
.design-ref/
